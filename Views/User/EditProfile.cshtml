@model Domain.Models.User
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Edit Profile | StyleBay</title>

    <!-- Separate CSS ONLY for Edit Profile -->
    <link rel="stylesheet" href="/css/editprofile.css" />
</head>
<body>

    <!-- HEADER -->
    <header>
        <div class="header-left">StyleBay</div>
    </header>

    <!-- CENTERED FORM -->
    <div class="profile-wrapper">
        <div class="profile-card">

            <h3 class="profile-heading">Edit Profile</h3>

            <form method="post" action="/User/EditProfile" class="edit-grid">

                <div class="form-group">
                    <input type="text"
                           name="Name"
                           value="@Model.Name"
                           class="profile-input"
                           placeholder="Name"
                           required />
                </div>

                <div class="form-group">
                    <input asp-for="Email"
                           class="profile-input"
                           placeholder="Email"
                           type="email"
                           required
                           title="Please enter a valid email address (example: name@gmail.com)" />

                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <div class="form-group full">
                    <input type="password"
                           name="PasswordHash"
                           value="@Model.PasswordHash"
                           class="profile-input"
                           placeholder="Password" />
                </div>
                <div class="form-group">
                    <input type="text"
                           name="Address"
                           value="@Model.Address"
                           class="profile-input"
                           placeholder="Address" />
                </div>

                <div class="form-group">
                    <input type="text"
                           name="City"
                           value="@Model.City"
                           class="profile-input"
                           placeholder="City" />
                </div>

                <div class="form-group">
                    <input asp-for="PhoneNumber"
                           class="profile-input"
                           placeholder="Phone Number"
                           maxlength="10"
                           minlength="10"
                           pattern="\d{10}"
                           title="Phone number must be exactly 10 digits"
                           required />

                    <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <input asp-for="PinCode"
                           class="profile-input"
                           placeholder="Pin Code"
                           maxlength="6"
                           minlength="6"
                           pattern="\d{6}"
                           title="Pin code must be exactly 6 digits"
                           required />

                    <span asp-validation-for="PinCode" class="text-danger"></span>
                </div>



                <div class="form-actions full">
                    <button type="submit" class="btn-update">Save Changes</button>
                    <button type="button"
                            class="btn-outline-pink"
                            onclick="location.href='/User/Profile'">
                        Cancel
                    </button>
                </div>

            </form>

        </div>
    </div>
    @section Scripts {
        <partial name="_ValidationScriptsPartial" />
    }

</body>
</html>